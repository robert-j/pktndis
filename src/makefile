# PKTNDIS
#
# This is a makefile for Borland MAKE as it comes with Borland Pascal.
#
# Author has no experience with Borland MAKE, but since the GitHub version
# of PKTNDIS must not depend on a large tool chain we provide a compatible
# makefile variant.
#
# BROOT must be configured to point to your Borland Pascal installation.
#

BPROOT	 = c:\bp
RTL	 = $(BPROOT)\units
BPCFLAGS = /U$(RTL)
BPC      = $(BPROOT)\bin\bpc.exe $(BPCFLAGS) $(FLAGS)
XDATE    = ..\bin\xdate.exe
MKDIR	 = md
CP       = copy
RM       = del
RMDIR    = rd

all:	 pktndis

pktndis: prepare
	$(BPC) -Ebuild $@

prepare:
	@$(MKDIR) build
	@$(XDATE) (* Generated by 'Makefile'. Do not edit. *) 	> stamp.inc
	@$(XDATE) const ProductDateTime = 'GitHub $c$';     	>> stamp.inc

dist:	pktndis
	@$(MKDIR) dist
	$(CP) build\pktndis.exe dist\pktndis.dos
	$(CP) ..\etc\*.inf dist
	$(CP) ..\etc\*.md  dist

clean:
	$(RM) build\*.tpu
	$(RM) build\*.exe
	$(RM) build\*.map
	$(RM) stamp.inc
	$(RMDIR) build
	$(RM) dist\*.dos
	$(RM) dist\*.inf
	$(RM) dist\*.md
	$(RMDIR) dist
